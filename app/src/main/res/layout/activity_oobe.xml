<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center">

    <ImageView
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:src="@mipmap/ic_launcher"
        android:layout_marginBottom="32dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/oobe_title"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textAlignment="center"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/oobe_description"
        android:textSize="16sp"
        android:textColor="@color/gray"
        android:textAlignment="center"
        android:layout_marginBottom="48dp"/>

    <TextView
        android:id="@+id/permission_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/oobe_permission_progress"
        android:textSize="14sp"
        android:textColor="@color/gray"
        android:textAlignment="center"
        android:layout_marginBottom="24dp"/>

    <fan.miuix.widget.Button
        android:id="@+id/grant_permissions_button"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="@string/oobe_grant_permissions"
        android:textSize="16sp"
        android:textColor="@color/white"
        android:background="@drawable/button_primary"
        android:layout_marginBottom="16dp"
        android:elevation="4dp"/>

    <fan.miuix.widget.Button
        android:id="@+id/manage_storage_button"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="@string/oobe_manage_storage"
        android:textSize="16sp"
        android:textColor="@color/white"
        android:background="@drawable/button_primary"
        android:layout_marginBottom="16dp"
        android:elevation="4dp"/>

    <fan.miuix.widget.Button
        android:id="@+id/next_button"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="@string/oobe_next"
        android:textSize="16sp"
        android:textColor="@color/white"
        android:background="@drawable/button_primary"
        android:elevation="4dp"
        android:enabled="false"
        android:alpha="0.5"/>

</LinearLayout>